{
  "name": "shorts-generator",
  "version": "1.0.0",
  "private": true,
  "description": "Automated YouTube Shorts generator — downloads videos, transcribes with Whisper, identifies viral moments via LLM, generates vertical shorts with captions, and sends to Telegram.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "start": "tsx src/server/index.ts",
    "cli": "tsx src/cli.ts",
    "generate": "tsx src/cli.ts generate",
    "generate:url": "tsx src/cli.ts generate --url",
    "build": "tsc --noEmit",
    "web:dev": "pnpm --dir web run dev",
    "web:build": "pnpm --dir web run build",
    "web:preview": "pnpm --dir web run preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "ai": "^4.1.0",
    "dotenv": "^16.4.7",
    "fluent-ffmpeg": "^2.1.3",
    "glob": "^11.0.0",
    "grammy": "^1.31.0",
    "hono": "^4.6.0",
    "nanoid": "^5.0.9",
    "ollama-ai-provider": "^1.2.0",
    "p-limit": "^6.2.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
