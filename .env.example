# ─── YouTube Channels (comma-separated channel URLs or handles) ───
YOUTUBE_CHANNELS="@channelhandle1,@channelhandle2,UCxxxxxx"

# ─── How many days back to fetch videos (default: 1 = today) ───
DAYS_BACK=1

# ─── Ollama LLM (local, free — no API key needed) ───
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-vl:4b

# ─── Whisper local model size: tiny, base, small, medium, large ───
WHISPER_MODEL=base

# ─── Telegram Bot Token ───
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ─── Telegram Chat ID (channel or group) ───
TELEGRAM_CHAT_ID=-1001234567890

# ─── Output Directory for generated shorts ───
OUTPUT_DIR=./output

# ─── Maximum short duration in seconds (default: 59) ───
MAX_SHORT_DURATION=59

# ─── Minimum short duration in seconds (default: 15) ───
MIN_SHORT_DURATION=15

# ─── Server port (for web UI API) ───
PORT=3001

# ─── Specific video URLs to process (comma-separated, optional) ───
# VIDEO_URLS=https://www.youtube.com/watch?v=xxx,https://www.youtube.com/watch?v=yyy
